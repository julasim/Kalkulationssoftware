# ─── PostgreSQL (docker-compose Service "db") ───────────────────────────────
POSTGRES_USER=lv_user
POSTGRES_PASSWORD=bitte-aendern-sicheres-passwort
POSTGRES_DB=lv_manager

# ─── App ────────────────────────────────────────────────────────────────────
# JWT-Secret — mind. 32 Zeichen zufällig. Tipp: openssl rand -base64 32
JWT_SECRET=bitte-aendern-mind-32-zeichen-zufaellig

# Port, unter dem die App (API + Web-UI) am Host erreichbar ist
APP_PORT=3000

# Erst-Admin für den Seed (Passwort leer lassen = Standard 'changeme123')
SEED_ADMIN_EMAIL=julius@sima.or.at
SEED_ADMIN_PASSWORD=
