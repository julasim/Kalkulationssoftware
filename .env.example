# ─── PostgreSQL (Compose-Service "db") ──────────────────────────────────────
# Werden auch zum Aufbau der DATABASE_URL des api-Service verwendet.
POSTGRES_USER=lv_user
POSTGRES_PASSWORD=bitte-aendern-sicheres-passwort
POSTGRES_DB=lv_manager

# ─── API (Compose-Service "api") ────────────────────────────────────────────
# JWT-Secret zum Signieren der Auth-Tokens — mind. 32 Zeichen zufällig.
# Tipp: openssl rand -base64 48   (install.sh setzt diesen Wert automatisch)
JWT_SECRET=bitte-aendern-mind-32-zeichen-zufaellig

# ─── Edge-Proxy-Anbindung (Compose-Service "web") ───────────────────────────
# Name des bestehenden EXTERNEN Docker-Netzes des zentralen Caddy-Edge-Proxys.
# Mit `docker network ls` prüfen — oft "proxy" oder "proxy_default".
PROXY_NETWORK=proxy
# Domain, unter der die App über den Edge-Proxy erreichbar ist.
# Nur für Hinweise/Caddyfile-Block — die App veröffentlicht selbst KEINEN Port.
DOMAIN=kalkulation.sima.business

# ─── Erst-Admin (db:seed) ───────────────────────────────────────────────────
# Passwort leer lassen = Standardpasswort 'changeme123' (danach unbedingt ändern).
SEED_ADMIN_EMAIL=julius@sima.or.at
SEED_ADMIN_PASSWORD=
