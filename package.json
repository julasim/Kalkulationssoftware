{
  "name": "lv-manager",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:mcp": "pnpm --filter mcp dev",
    "dev:web": "pnpm --filter desktop dev",
    "build": "pnpm --filter desktop build && pnpm --filter api build",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:deploy": "pnpm --filter api db:deploy",
    "db:studio": "pnpm --filter api db:studio",
    "db:seed": "pnpm --filter api db:seed",
    "db:generate": "pnpm --filter api db:generate"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
