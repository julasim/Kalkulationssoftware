# PostgreSQL Verbindung
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://lv_user:deinpasswort@localhost:5432/lv_manager"

# JWT Secret — mindestens 32 Zeichen, zufällig generieren
# Tipp: openssl rand -base64 32
JWT_SECRET="change-me-to-a-random-32-char-secret"

# API Port
PORT=3000
