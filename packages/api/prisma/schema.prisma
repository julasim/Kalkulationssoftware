generator client {
  provider      = "prisma-client-js"
  // "native" für lokale Entwicklung, "debian-openssl-3.0.x" für das Docker-Image
  // (node:22-bookworm-slim = Debian 12 / OpenSSL 3.0).
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Benutzer ────────────────────────────────────────────────────────────────

enum UserRole {
  admin
  editor
  viewer
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         UserRole  @default(editor)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  projekte     Projekt[]
}

// ─── Projekte ─────────────────────────────────────────────────────────────────

enum ProjektStatus {
  offen
  in_arbeit
  abgeschlossen
  archiviert
}

model Projekt {
  id          String        @id @default(cuid())
  name        String
  beschreibung String?
  status      ProjektStatus @default(offen)
  ort         String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  createdBy   User          @relation(fields: [userId], references: [id])
  userId      String

  lvs         LV[]
}

// ─── Leistungsverzeichnis ─────────────────────────────────────────────────────

model LV {
  id          String    @id @default(cuid())
  version     Int       @default(1)
  bezeichnung String
  notiz       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  projekt     Projekt   @relation(fields: [projektId], references: [id], onDelete: Cascade)
  projektId   String

  titel       LVTitel[]
  angebote    Angebot[]
}

// ─── Titel / Gliederung ───────────────────────────────────────────────────────

model LVTitel {
  id          String      @id @default(cuid())
  nummer      String      // z.B. "01", "02"
  bezeichnung String
  reihenfolge Int         @default(0)

  lv          LV          @relation(fields: [lvId], references: [id], onDelete: Cascade)
  lvId        String

  // Selbstreferenz für Untertitel
  parentId    String?
  parent      LVTitel?    @relation("Untertitel", fields: [parentId], references: [id])
  kinder      LVTitel[]   @relation("Untertitel")

  positionen  Position[]
}

// ─── Position ─────────────────────────────────────────────────────────────────

enum PositionTyp {
  normal
  alternativ
  eventualposition
  pauschale
}

model Position {
  id              String        @id @default(cuid())
  nummer          String        // z.B. "01.01"
  kurztext        String
  langtext        String?
  menge           Decimal       @db.Decimal(12, 3)
  einheit         String        // m², m³, lfm, Stk, psch, ...
  typ             PositionTyp   @default(normal)
  reihenfolge     Int           @default(0)

  // Referenz auf Katalogposition (optional)
  katalogPos      KatalogPosition? @relation(fields: [katalogPosId], references: [id])
  katalogPosId    String?

  titel           LVTitel       @relation(fields: [titelId], references: [id], onDelete: Cascade)
  titelId         String

  kalkulation     Kalkulation?
}

// ─── Kalkulation ──────────────────────────────────────────────────────────────

model Kalkulation {
  id            String    @id @default(cuid())
  updatedAt     DateTime  @updatedAt

  // Zuschlagssätze (überschreiben Projekt-Standard)
  agkProzent    Decimal   @default(5)   @db.Decimal(5, 2)
  guProzent     Decimal   @default(3)   @db.Decimal(5, 2)
  gewinnProzent Decimal   @default(3)   @db.Decimal(5, 2)

  // Berechneter EP (wird bei Speichern aktualisiert)
  einheitspreis Decimal?  @db.Decimal(12, 4)
  gesamtpreis   Decimal?  @db.Decimal(14, 2)

  position      Position  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  positionId    String    @unique

  lohnzeilen    KalkulationLohn[]
  materialzeilen KalkulationMaterial[]
  geraetezeilen KalkulationGeraet[]
  nuZeilen      KalkulationNU[]
  sonstigeZeilen KalkulationSonstige[]
}

model KalkulationLohn {
  id            String      @id @default(cuid())
  bezeichnung   String
  aufwandswert  Decimal     @db.Decimal(8, 3)  // h/Einheit
  stundensatz   Decimal     @db.Decimal(8, 2)  // €/h
  reihenfolge   Int         @default(0)

  kalkulation   Kalkulation @relation(fields: [kalkulationId], references: [id], onDelete: Cascade)
  kalkulationId String
}

model KalkulationMaterial {
  id            String      @id @default(cuid())
  bezeichnung   String
  menge         Decimal     @db.Decimal(10, 3)
  einheit       String
  preis         Decimal     @db.Decimal(10, 4)  // €/Einheit
  aufschlag     Decimal     @default(0) @db.Decimal(5, 2)  // %
  reihenfolge   Int         @default(0)

  kalkulation   Kalkulation @relation(fields: [kalkulationId], references: [id], onDelete: Cascade)
  kalkulationId String
}

model KalkulationGeraet {
  id            String      @id @default(cuid())
  bezeichnung   String
  menge         Decimal     @db.Decimal(10, 3)
  einheit       String
  preis         Decimal     @db.Decimal(10, 4)
  reihenfolge   Int         @default(0)

  kalkulation   Kalkulation @relation(fields: [kalkulationId], references: [id], onDelete: Cascade)
  kalkulationId String
}

model KalkulationNU {
  id            String      @id @default(cuid())
  bezeichnung   String
  betrag        Decimal     @db.Decimal(12, 2)  // €/Einheit
  reihenfolge   Int         @default(0)

  kalkulation   Kalkulation @relation(fields: [kalkulationId], references: [id], onDelete: Cascade)
  kalkulationId String
}

model KalkulationSonstige {
  id            String      @id @default(cuid())
  bezeichnung   String
  betrag        Decimal     @db.Decimal(12, 2)
  reihenfolge   Int         @default(0)

  kalkulation   Kalkulation @relation(fields: [kalkulationId], references: [id], onDelete: Cascade)
  kalkulationId String
}

// ─── Katalog / Leistungsbücher ──────────────────────────────────────────────

enum LeistungsbuchTyp {
  oenorm   // importiertes ÖNORM-Leistungsbuch (read-only)
  eigen    // eigener/Firmen-Stammkatalog (editierbar)
}

enum ImportStatus {
  pending
  running
  done
  error
}

model Leistungsbuch {
  id             String           @id @default(cuid())
  kennung        String           // z.B. "HB", "VI", "HT"
  bezeichnung    String           // z.B. "Leistungsbeschreibung Hochbau"
  versionsnummer String           // z.B. "23"
  versionsdatum  DateTime?
  herausgeber    String?
  typ            LeistungsbuchTyp @default(oenorm)
  aktiv          Boolean          @default(true)
  dateiname      String?          // Original-Dateiname des Uploads
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  positionen     KatalogPosition[]
  importJobs     ImportJob[]

  @@unique([kennung, versionsnummer])
}

model ImportJob {
  id              String         @id @default(cuid())
  leistungsbuch   Leistungsbuch? @relation(fields: [leistungsbuchId], references: [id], onDelete: SetNull)
  leistungsbuchId String?
  dateiname       String
  status          ImportStatus   @default(pending)
  processed       Int            @default(0)
  total           Int            @default(0)
  message         String?
  createdAt       DateTime       @default(now())
  finishedAt      DateTime?
}

model KatalogPosition {
  id            String      @id @default(cuid())
  lbNummer      String      // z.B. "LB-HB 23" (denormalisiert, Anzeige)
  posNummer     String      // verkettet: LG+ULG+GT+FT, z.B. "001001A"
  kurztext      String      // <stichwort>
  langtext      String?     // Folgeposition-Langtext (bereinigtes Light-HTML)
  grundtextLang String?     // gemeinsamer Grundtext-Langtext (Light-HTML)
  einheit       String
  quelle        String      // "LB-HB", "LB-H", "eigen" (denormalisiert, Anzeige)
  tags          String[]

  // ÖNORM-Hierarchie (A2063)
  lgNr           String?    // Leistungsgruppe, z.B. "02"
  ulgNr          String?    // Untergruppe, z.B. "36"
  gtNr           String?    // Grundtextnummer, z.B. "04"
  ftNr           String?    // Folgepositionskennung, z.B. "A"
  lgBezeichnung  String?    // Überschrift der Leistungsgruppe
  ulgBezeichnung String?    // Überschrift der Untergruppe

  leistungsbuch   Leistungsbuch @relation(fields: [leistungsbuchId], references: [id], onDelete: Cascade)
  leistungsbuchId String

  positionen    Position[]

  @@unique([leistungsbuchId, posNummer])
  @@index([lgNr, ulgNr])
}

// ─── Angebote ─────────────────────────────────────────────────────────────────

model Angebot {
  id            String    @id @default(cuid())
  bezeichnung   String
  createdAt     DateTime  @default(now())

  // Snapshot der LV-Daten zum Zeitpunkt des Exports
  snapshotJson  Json

  // Berechnete Summen
  summeNetto    Decimal   @db.Decimal(14, 2)
  summeBrutto   Decimal?  @db.Decimal(14, 2)
  mwstProzent   Decimal   @default(20) @db.Decimal(5, 2)

  lv            LV        @relation(fields: [lvId], references: [id])
  lvId          String
}
